# ─── eventone Frontend Environment ───────────────────────────────────────────
#
# HOW TO USE:
#   Copy this file to .env for local development (usually not needed).
#   For Docker / production deploys, set VITE_API_URL to your backend URL.
#
# LOCAL DEV (default):
#   Leave VITE_API_URL empty. The Vite dev server proxy handles /api requests
#   automatically (see vite.config.js). No changes needed.
#
# PRODUCTION / DOCKER:
#   Set VITE_API_URL to the full URL of your deployed backend.
#   Example: VITE_API_URL=https://api.eventone.your-domain.com
#
# ─────────────────────────────────────────────────────────────────────────────

VITE_API_URL=
